{
  "expo": {
    "name": "Resume Builder",
    "slug": "resume-builder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C63FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.resumebuilder",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to let you select a profile picture for your resume.",
        "NSCameraUsageDescription": "We need camera access to take a profile picture for your resume."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "package": "com.yourname.resumebuilder",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set a profile picture on your resume.",
          "cameraPermission": "The app uses your camera to let you take a profile photo."
        }
      ],
      "expo-sharing"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "01e6c2f9-24a5-4199-a884-2e0807cfbbe0"
      }
    }
  }
}
